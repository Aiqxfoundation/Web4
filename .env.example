# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/etr_gem_mining

# ── Authentication ────────────────────────────────────────────────────────────
# A long random secret used to sign JWT tokens (required in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production (e.g. https://yourdomain.com)
# Leaving unset allows all origins (only safe in development)
ALLOWED_ORIGIN=https://yourdomain.com

# ── Ports ─────────────────────────────────────────────────────────────────────
# API server port (default: 8080)
PORT=8080
# Frontend dev server port (default: 20501)
# PORT=20501
